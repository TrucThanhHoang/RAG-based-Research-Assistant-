DATABASE_URL=postgresql+psycopg2://postgres:postgres@postgres:5432/rag_db
JWT_SECRET_KEY=change-me
OPENAI_API_KEY=sk-proj-your-openai-api-key-here
ANTHROPIC_API_KEY=sk-ant-your-anthropic-api-key-here
# Optional: dùng proxy thay vì Anthropic gốc (vd. gwai)
# Lưu ý: KHÔNG có /v1 ở cuối — Anthropic SDK tự append /v1/messages
# Khi dùng gwai, model name phải là claude-sonnet-4-6, claude-opus-4-6, claude-haiku-4-5
# ANTHROPIC_BASE_URL=https://1gw.gwai.cloud
GOOGLE_API_KEY=AIza-your-google-api-key-here
LLM_PROVIDER=openai
LLM_MODEL_NAME=gpt-4o-mini
EMBEDDING_MODEL_NAME=sentence-transformers/all-MiniLM-L6-v2
RETRIEVAL_TOP_K=5
FRONTEND_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:8000/api
INITIAL_ADMIN_EMAIL=admin@example.com
INITIAL_ADMIN_PASSWORD=Admin123!
INITIAL_ADMIN_NAME=Administrator
